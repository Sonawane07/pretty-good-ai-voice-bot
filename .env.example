# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Safety: all challenge calls must go only to this number.
TARGET_PHONE_NUMBER=+18054398008

# Public URL for local webhook/media stream during development.
# Example from ngrok, Cloudflare Tunnel, or another HTTPS tunnel.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# OpenAI
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini

# Runtime
CALL_RECORDINGS_DIR=data/recordings
CALL_TRANSCRIPTS_DIR=data/transcripts
CALL_REPORTS_DIR=data/reports
LOG_LEVEL=INFO
